# Atualizar o sistema completamente
sudo apt update && sudo apt full-upgrade -y

# Ferramentas de compilação e desenvolvimento
sudo apt install -y \
  build-essential gcc g++ gfortran make cmake autoconf automake libtool \
  pkg-config git curl wget ca-certificates gnupg2 lsb-release

# Bibliotecas essenciais para bioinformática
sudo apt install -y \
  zlib1g-dev libbz2-dev liblzma-dev libssl-dev libcurl4-openssl-dev \
  libxml2-dev libncurses5-dev libreadline-dev libffi-dev libsqlite3-dev \
  libblas-dev liblapack-dev libopenblas-dev

# Python 3 base
sudo apt install -y python3 python3-pip python3-venv python3-dev

# Java (necessário para muitas ferramentas NGS)
sudo apt install -y default-jre default-jdk

# Ferramentas de sistema e produtividade
sudo apt install -y \
  htop btop tmux screen tree ncdu rsync pigz parallel \
  unzip p7zip-full dos2unix gawk sed mawk bc

# Controle de versão e utilitários de rede
sudo apt install -y \
  subversion sra-toolkit

sudo apt autoremove -y && sudo apt autoclean
